{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/courses/[slug]",
      "regex": "^/courses/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/courses/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/instructor/courses/[courseId]/assignments/new",
      "regex": "^/instructor/courses/([^/]+?)/assignments/new(?:/)?$",
      "routeKeys": {
        "nxtPcourseId": "nxtPcourseId"
      },
      "namedRegex": "^/instructor/courses/(?<nxtPcourseId>[^/]+?)/assignments/new(?:/)?$"
    },
    {
      "page": "/instructor/courses/[courseId]/assignments/[assignmentId]/submissions",
      "regex": "^/instructor/courses/([^/]+?)/assignments/([^/]+?)/submissions(?:/)?$",
      "routeKeys": {
        "nxtPcourseId": "nxtPcourseId",
        "nxtPassignmentId": "nxtPassignmentId"
      },
      "namedRegex": "^/instructor/courses/(?<nxtPcourseId>[^/]+?)/assignments/(?<nxtPassignmentId>[^/]+?)/submissions(?:/)?$"
    },
    {
      "page": "/instructor/courses/[courseId]/quizzes/new",
